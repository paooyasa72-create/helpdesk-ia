# Copia este archivo como .env y llena tus propios valores (NUNCA subas el .env real a GitHub)

# MongoDB Atlas -> Connect -> Drivers -> copia el connection string
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/helpdesk?retryWrites=true&w=majority

# Google AI Studio -> Get API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_api_key_de_gemini

# Trello -> https://trello.com/power-ups/admin -> API Key, y Token generado desde el link que te da esa página
TRELLO_API_KEY=tu_api_key_de_trello
TRELLO_TOKEN=tu_token_de_trello
TRELLO_LIST_ID=id_de_la_lista_donde_se_crean_las_tarjetas

# Cualquier texto largo y aleatorio, usado para firmar las sesiones de login.
# Puedes generar uno en https://randomkeygen.com o inventar una frase larga.
JWT_SECRET=cambia_esto_por_un_texto_largo_y_aleatorio

PORT=3000
